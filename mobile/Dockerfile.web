# Mobile web build (react-native-web) → static SPA served by nginx.
# Build: docker build -f Dockerfile.web --build-arg EXPO_PUBLIC_API_URL=https://niki.ieu.app -t niki-web .
# Run:   docker run -p 8080:80 niki-web
#
# NOTE: EXPO_PUBLIC_API_URL is INLINED AT BUILD TIME, so it must be passed as a
# build-arg (not a runtime env). It is the backend origin the web app calls.

FROM node:20-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
ARG EXPO_PUBLIC_API_URL
ENV EXPO_PUBLIC_API_URL=$EXPO_PUBLIC_API_URL
RUN npx expo export --platform web && node scripts/inject-pwa.mjs

FROM nginx:alpine
COPY nginx.web.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
  CMD wget -qO- http://localhost/ >/dev/null 2>&1 || exit 1
CMD ["nginx", "-g", "daemon off;"]
