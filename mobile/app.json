{
  "expo": {
    "name": "Niki The Cat",
    "slug": "niki-coffee",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/brands/niki-logo-full.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "niki-coffee",
    "splash": {
      "image": "./assets/images/brands/niki-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "image": "./assets/images/brands/niki-logo-white.png",
        "resizeMode": "contain",
        "backgroundColor": "#121212"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nikicoffee.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/brands/niki-logo-full.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.nikicoffee.app"
    },
    "web": {
      "favicon": "./assets/images/brands/niki-logo-full.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "QR kod okumak için kamera izni gereklidir."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Profil fotoğrafı seçmek için galeri izni gereklidir."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/brands/niki-logo-full.png",
          "color": "#000000"
        }
      ],
      "expo-localization",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}