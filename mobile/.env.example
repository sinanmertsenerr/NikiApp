# ─────────────────────────────────────────────────────────────────────────────
# Mobile / Web environment
# ─────────────────────────────────────────────────────────────────────────────
# EXPO_PUBLIC_* vars are INLINED AT BUILD TIME by Expo (not read at runtime), so
# you must set this BEFORE `expo start --web` / `expo export --platform web`.
#
# WEB ONLY: the backend host the web build talks to (API + /uploads images).
# Native (iOS/Android) ignores this and always uses the live host.
#
#   Local dev (run backend locally on :3000):
#     EXPO_PUBLIC_API_URL=http://localhost:3000
#   Production web build (point at the deployed API):
#     EXPO_PUBLIC_API_URL=https://api.niki.ieu.app
#
# If unset, the web build falls back to https://niki.ieu.app.
EXPO_PUBLIC_API_URL=http://localhost:3000
