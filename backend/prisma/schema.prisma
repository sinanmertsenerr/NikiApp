// Niki Coffee - Prisma Schema
// Based on Technical Design Document v1.1

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  customer
  admin
  super_admin
}

enum Language {
  en
  tr
}

enum Theme {
  light
  dark
}

enum Brand {
  coffee
  sandwich
}

enum TransactionType {
  topup
  payment
  refund
  reward
}

enum OrderStatus {
  pending
  approved
  rejected
}

enum CampaignType {
  auto
  manual
}

enum RewardType {
  manual
  free_coffee
  discount_percent
  discount_fixed
  bonus_points
}

enum CampaignStatus {
  active
  used
  expired
}

enum BadgeCriteriaType {
  coffee_count
  points_earned
  wheel_wins
  consecutive_visits
  first_order
}

enum WheelRewardType {
  points
  discount
  free_coffee
  free_cookie
  retry
  second_drink_discount
  coffee_and_cookie
  badge
  nothing
}

enum WalletType {
  IEU   // İEÜ Cüzdan - 15% discount
  NIKI  // Niki Cüzdan - 10% discount
}

enum RaffleStatus {
  pending    // Not started yet
  active     // Ongoing, participation open
  completed  // Draw completed
  cancelled  // Cancelled
}

// ==================== MODELS ====================

model User {
  id                      String    @id @default(uuid())
  email                   String    @unique
  passwordHash            String    @map("password_hash")
  firstName               String    @map("first_name")
  lastName                String    @map("last_name")
  bio                     String?
  phone                   String?
  avatarUrl               String?   @map("avatar_url")
  role                    UserRole  @default(customer)
  language                Language  @default(tr)
  theme                   Theme     @default(light)
  selectedBrand           Brand     @default(coffee) @map("selected_brand")

  // Email Verification
  emailVerified           Boolean   @default(false) @map("email_verified")
  emailVerifiedAt         DateTime? @map("email_verified_at")

  // Push Notifications
  expoPushToken           String?   @map("expo_push_token")

  isActive                Boolean   @default(true) @map("is_active")
  lastLoginAt             DateTime? @map("last_login_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  // Relations
  wallets                 Wallet[]          // User can have multiple wallets (IEU, NIKI)
  loyaltyPoints           LoyaltyPoints?
  orders                  Order[]
  userCampaigns           UserCampaign[]
  userBadges              UserBadge[]
  wheelSpins              WheelSpin[]
  adminTransactions       Transaction[]   @relation("AdminTransactions")
  reviewedOrders          Order[]         @relation("ReviewedOrders")
  redeemedCampaigns       UserCampaign[]  @relation("RedeemedCampaigns")
  refreshTokens           RefreshToken[]
  groupMemberships        GroupMember[]
  notifications           Notification[]
  raffleParticipations    RaffleParticipant[]

  @@map("users")
}

model RefreshToken {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  token       String   @unique
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Wallet {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  walletType    WalletType    @default(IEU) @map("wallet_type")
  balance       Decimal       @default(0) @db.Decimal(10, 2)
  qrCode        String        @unique @map("qr_code")
  isActive      Boolean       @default(false) @map("is_active")
  allowNegative Boolean       @default(false) @map("allow_negative")
  negativeLimit Decimal       @default(0) @db.Decimal(10, 2) @map("negative_limit")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]

  @@unique([userId, walletType])  // Each user can have one wallet of each type
  @@map("wallets")
}

model LoyaltyPoints {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  totalPoints     Int      @default(0) @map("total_points")
  redeemedPoints  Int      @default(0) @map("redeemed_points")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("loyalty_points")
}

model Transaction {
  id                  String          @id @default(uuid())
  walletId            String          @map("wallet_id")
  type                TransactionType
  amount              Decimal         @db.Decimal(10, 2)
  originalAmount      Decimal?        @map("original_amount") @db.Decimal(10, 2)
  discountApplied     Decimal         @default(0) @map("discount_applied") @db.Decimal(10, 2)
  discountPercentage  Decimal         @default(0) @map("discount_percentage") @db.Decimal(5, 2)
  isFullPayment       Boolean         @default(false) @map("is_full_payment")
  balanceBefore       Decimal         @map("balance_before") @db.Decimal(10, 2)
  balanceAfter        Decimal         @map("balance_after") @db.Decimal(10, 2)
  adminId             String?         @map("admin_id")
  description         String?
  createdAt           DateTime        @default(now()) @map("created_at")

  // Relations
  wallet              Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  admin               User?           @relation("AdminTransactions", fields: [adminId], references: [id])

  @@index([walletId])
  @@index([createdAt(sort: Desc)])
  @@map("transactions")
}

model Category {
  id          String    @id @default(uuid())
  brand       Brand
  name        String
  nameTr      String    @map("name_tr")
  description String?
  descriptionTr String? @map("description_tr")
  imageUrl    String?   @map("image_url")
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  products    Product[]

  @@map("categories")
}

model Product {
  id            String    @id @default(uuid())
  categoryId    String    @map("category_id")
  name          String
  nameTr        String    @map("name_tr")
  description   String?
  descriptionTr String?   @map("description_tr")
  price         Decimal   @db.Decimal(10, 2)
  imageUrl      String?   @map("image_url")
  isCoffee      Boolean   @default(false) @map("is_coffee")
  isActive      Boolean   @default(true) @map("is_active")
  sortOrder     Int       @default(0) @map("sort_order")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  category      Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@map("products")
}

model Order {
  id                String      @id @default(uuid())
  userId            String      @map("user_id")
  receiptImageUrl   String      @map("receipt_image_url")
  detectedCoffees   Int         @default(0) @map("detected_coffees")
  pointsEarned      Int         @default(0) @map("points_earned")
  status            OrderStatus @default(pending)
  analysisResult    Json?       @map("analysis_result")
  adminNotes        String?     @map("admin_notes")
  reviewedBy        String?     @map("reviewed_by")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  // Relations
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer          User?       @relation("ReviewedOrders", fields: [reviewedBy], references: [id])

  @@index([userId])
  @@index([status])
  @@map("orders")
}

enum CampaignTargetType {
  users
  groups
}

model Campaign {
  id              String             @id @default(uuid())
  type            CampaignType
  targetType      CampaignTargetType @default(users) @map("target_type")
  title           String
  titleTr         String             @map("title_tr")
  description     String?
  descriptionTr   String?            @map("description_tr")
  rewardType      RewardType         @map("reward_type")
  rewardValue     Decimal?           @map("reward_value") @db.Decimal(10, 2)
  requiredPoints  Int                @default(10) @map("required_points")
  imageUrl        String?            @map("image_url")
  startDate       DateTime?          @map("start_date")
  endDate         DateTime?          @map("end_date")
  isActive        Boolean            @default(true) @map("is_active")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  // Relations
  userCampaigns   UserCampaign[]
  campaignGroups  CampaignGroup[]

  @@index([isActive])
  @@index([type, isActive])
  @@map("campaigns")
}

model UserCampaign {
  id          String         @id @default(uuid())
  userId      String         @map("user_id")
  campaignId  String         @map("campaign_id")
  status      CampaignStatus @default(active)
  assignedAt  DateTime       @default(now()) @map("assigned_at")
  expiresAt   DateTime?      @map("expires_at")  // Individual expiry for this assignment
  redeemedAt  DateTime?      @map("redeemed_at")
  redeemedBy  String?        @map("redeemed_by")

  // Relations
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign    Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  redeemer    User?          @relation("RedeemedCampaigns", fields: [redeemedBy], references: [id])

  @@unique([userId, campaignId, assignedAt])
  @@index([userId])
  @@index([status])
  @@map("user_campaigns")
}

model Badge {
  id            String            @id @default(uuid())
  name          String
  nameTr        String            @map("name_tr")
  description   String?
  descriptionTr String?           @map("description_tr")
  iconUrl       String?           @map("icon_url")
  criteriaType  BadgeCriteriaType @map("criteria_type")
  criteriaValue Int               @map("criteria_value")
  isActive      Boolean           @default(true) @map("is_active")
  createdAt     DateTime          @default(now()) @map("created_at")

  // Relations
  userBadges    UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  badgeId   String   @map("badge_id")
  earnedAt  DateTime @default(now()) @map("earned_at")

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

model WheelSpin {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  weekNumber  Int             @map("week_number")
  year        Int
  spinRights  Int             @default(1) @map("spin_rights")
  used        Boolean         @default(false)
  rewardType  WheelRewardType? @map("reward_type")
  rewardValue String?         @map("reward_value")
  spunAt      DateTime?       @map("spun_at")

  // Relations
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekNumber, year])
  @@index([userId])
  @@map("wheel_spins")
}

// ==================== GROUPS ====================

model Group {
  id          String        @id @default(uuid())
  name        String
  description String?
  isActive    Boolean       @default(true) @map("is_active")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  members     GroupMember[]
  campaignGroups CampaignGroup[]

  @@map("groups")
}

model GroupMember {
  id        String   @id @default(uuid())
  groupId   String   @map("group_id")
  userId    String   @map("user_id")
  addedAt   DateTime @default(now()) @map("added_at")

  // Relations
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("group_members")
}

model CampaignGroup {
  id          String    @id @default(uuid())
  campaignId  String    @map("campaign_id")
  groupId     String    @map("group_id")
  assignedAt  DateTime  @default(now()) @map("assigned_at")

  // Relations
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  group       Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([campaignId, groupId])
  @@index([campaignId])
  @@index([groupId])
  @@map("campaign_groups")
}

// ==================== NOTIFICATIONS ====================

enum NotificationType {
  campaign
  reward
  badge
  order
  system
  balance
}

model Notification {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  type        NotificationType
  title       String
  titleTr     String           @map("title_tr")
  message     String
  messageTr   String           @map("message_tr")
  isRead      Boolean          @default(false) @map("is_read")
  actionUrl   String?          @map("action_url")
  metadata    Json?
  createdAt   DateTime         @default(now()) @map("created_at")

  // Relations
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

// ==================== RAFFLES ====================

model Raffle {
  id              String         @id @default(uuid())
  title           String
  titleTr         String         @map("title_tr")
  description     String?
  descriptionTr   String?        @map("description_tr")
  
  // Reward info (for winner campaign creation)
  rewardType      RewardType     @map("reward_type")
  rewardValue     String?        @map("reward_value")
  
  // Duration
  startDate       DateTime       @map("start_date")
  endDate         DateTime       @map("end_date")
  
  // Number of winners (default 1)
  winnerCount     Int            @default(1) @map("winner_count")
  
  status          RaffleStatus   @default(pending)
  drawnAt         DateTime?      @map("drawn_at")
  
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  
  // Relations
  participants    RaffleParticipant[]
  
  @@index([status])
  @@index([endDate])
  @@map("raffles")
}

model RaffleParticipant {
  id              String    @id @default(uuid())
  raffleId        String    @map("raffle_id")
  userId          String    @map("user_id")
  isWinner        Boolean   @default(false) @map("is_winner")
  joinedAt        DateTime  @default(now()) @map("joined_at")
  
  // If winner, the assigned campaign
  userCampaignId  String?   @map("user_campaign_id")
  usedAt          DateTime? @map("used_at")
  
  // Relations
  raffle          Raffle    @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([raffleId, userId])
  @@index([raffleId])
  @@index([userId])
  @@map("raffle_participants")
}
