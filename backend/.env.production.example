# ====================
# DATABASE (PostgreSQL - Docker internal network)
# ====================
# For Docker: use 'postgres' as host (container name)
DATABASE_URL="postgresql://nikiuser:STRONG_PASSWORD@postgres:5432/niki_coffee?schema=public"
POSTGRES_USER="nikiuser"
POSTGRES_PASSWORD="STRONG_PASSWORD"
POSTGRES_DB="niki_coffee"

# ====================
# JWT SECRETS (GENERATE WITH: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
# ====================
JWT_SECRET="REPLACE_WITH_64_CHAR_HEX_1"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="REPLACE_WITH_64_CHAR_HEX_2"
JWT_REFRESH_EXPIRES_IN="7d"

# ====================
# REDIS (Docker internal network)
# ====================
# For Docker: use 'redis' as host (container name)
REDIS_HOST="redis"
REDIS_PORT=6379
# REDIS_PASSWORD="STRONG_REDIS_PASSWORD"  # Optional for internal network

# ====================
# EMAIL (Production SMTP)
# ====================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM_NAME="Niki Coffee"
SMTP_FROM_EMAIL="noreply@nikicoffe.com"

# ====================
# APPLICATION
# ====================
APP_NAME="Niki Coffee"
APP_PORT=3000
NODE_ENV="production"

# ====================
# SECURITY
# ====================
HTTPS_ONLY="true"
FRONTEND_URL="https://niki.ieu.app"
PRODUCTION_APP_URL="https://api.niki.ieu.app"
# Mobile web build (react-native-web) origin. Added to BOTH the REST CORS
# (main.ts) and the WebSocket gateway allowlist (events.gateway.ts). Set this to
# wherever the web app is hosted (test domain below).
WEB_APP_URL="https://nikiapp.sinansener.com"
# Existing admin dashboard origin (optional; defaults to http://localhost:5173)
DASHBOARD_URL="https://dashboard.niki.ieu.app"

# ====================
# MONITORING (Sentry)
# ====================
SENTRY_DSN="https://your-project-id@o4507076471349248.ingest.us.sentry.io/1234567"
SENTRY_ENVIRONMENT="production"
SENTRY_TRACES_SAMPLE_RATE="0.1"

# ====================
# EMAIL VERIFICATION
# ====================
VERIFICATION_CODE_TTL=900
RESEND_COOLDOWN=60
MAX_VERIFICATION_ATTEMPTS=5

# ====================
# LOYALTY
# ====================
NIKI_CREDIT_DISCOUNT_PERCENTAGE=15
POINTS_FOR_FREE_COFFEE=10
