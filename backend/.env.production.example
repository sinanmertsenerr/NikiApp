# ====================
# DATABASE (PostgreSQL with SSL)
# ====================
DATABASE_URL="postgresql://niki_user:STRONG_PASSWORD@db-host:5432/niki_coffee?schema=public&sslmode=require&connect_timeout=10"

# ====================
# JWT SECRETS (GENERATE WITH: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
# ====================
JWT_SECRET="REPLACE_WITH_64_CHAR_HEX_1"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="REPLACE_WITH_64_CHAR_HEX_2"
JWT_REFRESH_EXPIRES_IN="7d"

# ====================
# REDIS (with authentication)
# ====================
REDIS_HOST="redis-host"
REDIS_PORT=6379
REDIS_PASSWORD="STRONG_REDIS_PASSWORD"

# ====================
# EMAIL (Production SMTP)
# ====================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM_NAME="Niki Coffee"
SMTP_FROM_EMAIL="noreply@nikicoffe.com"

# ====================
# APPLICATION
# ====================
APP_NAME="Niki Coffee"
APP_PORT=3000
NODE_ENV="production"

# ====================
# SECURITY
# ====================
HTTPS_ONLY="true"
FRONTEND_URL="https://app.nikicoffe.com"
PRODUCTION_APP_URL="https://app.nikicoffe.com"

# ====================
# MONITORING (Sentry)
# ====================
SENTRY_DSN="https://your-project-id@o4507076471349248.ingest.us.sentry.io/1234567"
SENTRY_ENVIRONMENT="production"
SENTRY_TRACES_SAMPLE_RATE="0.1"

# ====================
# EMAIL VERIFICATION
# ====================
VERIFICATION_CODE_TTL=900
RESEND_COOLDOWN=60
MAX_VERIFICATION_ATTEMPTS=5

# ====================
# LOYALTY
# ====================
NIKI_CREDIT_DISCOUNT_PERCENTAGE=15
POINTS_FOR_FREE_COFFEE=10
